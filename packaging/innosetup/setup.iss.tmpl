[Code]

function NeedsAddPath(AppPath: string): Boolean;
var
  RootKey: Integer;
  SubKey: string;
  RawPath: string;
begin
  if IsAdmin() then
  begin
    RootKey := HKLM;
    SubKey  := 'SYSTEM\CurrentControlSet\Control\Session Manager\Environment';
  end 
  else begin
    RootKey := HKCU;
    SubKey  := 'Environment';
  end;

  if RegQueryStringValue(RootKey, SubKey, 'PATH', RawPath) then    
    Result := Pos(';' + AppPath + ';', ';' + RawPath + ';') = 0
  else
    Result := True;
end;

function TrimStr(const S: string): string;
var
  I, J: Integer;
begin
  I := 1;
  while (I <= Length(S)) and (S[I] = ' ') do Inc(I);
  J := Length(S);
  while (J >= I) and (S[J] = ' ') do Dec(J);
  Result := Copy(S, I, J - I + 1);
end;

// Splits PATH string into individual entries, trimming whitespace from each.
// Skips empty entries produced by double semicolons or leading/trailing semicolons.
procedure SplitPath(const RawPath: string; Parts: TStringList);
var
  I, Start: Integer;
  Entry: string;
begin
  Start := 1;
  for I := 1 to Length(RawPath) do
  begin
    if RawPath[I] = ';' then
    begin
      Entry := TrimStr(Copy(RawPath, Start, I - Start));
      if Entry <> '' then
        Parts.Add(Entry);
      Start := I + 1;
    end;
  end;
  // Last segment after final semicolon (or whole string if no semicolon)
  Entry := TrimStr(Copy(RawPath, Start, Length(RawPath) - Start + 1));
  if Entry <> '' then
    Parts.Add(Entry);
end;

// Reassembles a TStringList of path entries into a semicolon-delimited string.
function JoinPath(Parts: TStringList): string;
var
  I: Integer;
begin
  Result := '';
  for I := 0 to Parts.Count - 1 do
  begin
    if Result <> '' then
      Result := Result + ';';
    Result := Result + Parts[I];
  end;
end;

// Case-insensitive path comparison, also normalises trailing backslash.
function PathsEqual(const A, B: string): Boolean;
var
  NormA, NormB: string;
begin
  NormA := A;
  NormB := B;
  // Strip trailing backslash for comparison only
  if (Length(NormA) > 0) and (NormA[Length(NormA)] = '\') then
    NormA := Copy(NormA, 1, Length(NormA) - 1);
  if (Length(NormB) > 0) and (NormB[Length(NormB)] = '\') then
    NormB := Copy(NormB, 1, Length(NormB) - 1);
  Result := CompareText(NormA, NormB) = 0;
end;

procedure RemoveAppFromPath(const AppPath: string);
var
  RootKey: Integer;
  SubKey: string;
  RawPath: string;
  Parts, NewParts: TStringList;
  I: Integer;
  Removed: Boolean;
begin
  if IsAdmin() then
  begin
    RootKey := HKLM;
    SubKey  := 'SYSTEM\CurrentControlSet\Control\Session Manager\Environment';
  end else
  begin
    RootKey := HKCU;
    SubKey  := 'Environment';
  end;

  if not RegQueryStringValue(RootKey, SubKey, 'PATH', RawPath) then
    Exit; // PATH key doesn't exist — nothing to do

  Parts    := TStringList.Create;
  NewParts := TStringList.Create;
  try
    SplitPath(RawPath, Parts);

    Removed := False;
    for I := 0 to Parts.Count - 1 do
    begin
      // Expand any %variables% in stored entry before comparing
      if PathsEqual(ExpandConstant(Parts[I]), AppPath) or
         PathsEqual(Parts[I], AppPath) then
        Removed := True  // drop this entry
      else
        NewParts.Add(Parts[I]);  // keep everything else untouched
    end;

    // Only write back if we actually changed something
    if Removed then
      RegWriteExpandStringValue(RootKey, SubKey, 'PATH', JoinPath(NewParts));

  finally
    Parts.Free;
    NewParts.Free;
  end;
end;

procedure CurUninstallStepChanged(CurUninstallStep: TUninstallStep);
begin
  if CurUninstallStep = usUninstall then
  begin
    RemoveAppFromPath(ExpandConstant('{app}'));    
  end;
end;